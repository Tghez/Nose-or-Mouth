{
  "name": "mouth-breather",
  "version": "1.0.0",
  "description": "Real-time mouth/nose breathing monitor",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:mac": "electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.tghez.mouth-breather",
    "productName": "Mouth Breather",
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "identity": null,
      "extendInfo": {
        "NSCameraUsageDescription": "Mouth Breather needs camera access to detect breathing patterns."
      }
    }
  }
}
