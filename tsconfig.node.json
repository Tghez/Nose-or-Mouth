{
  "compilerOptions": {
    "composite": true,
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "out"
  },
  "include": ["src/main/**/*", "src/preload/**/*", "src/types/**/*", "electron.vite.config.ts"]
}
